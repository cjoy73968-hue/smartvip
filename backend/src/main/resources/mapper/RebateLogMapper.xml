<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.smartvip.mapper.RebateLogMapper">
    <select id="selectPendingRebate" resultType="com.smartvip.entity.RebateLog">
        SELECT id, referrer_id, order_id, order_type, amount, status, arrive_time, create_time
        FROM rebate_logs WHERE status = 0
    </select>
</mapper>
